# --- Configurações de Servidor ---
Options -Indexes
Options -MultiViews

RewriteEngine On
RewriteBase /

# Página de erro personalizada
ErrorDocument 404 /404.php

# --- Otimização de Performance (Essencial para 384MB) ---

# 1. Ativar compressão GZIP (Reduz o tamanho dos arquivos enviados)
<IfModule mod_deflate.c>
    AddOutputFilterByType DEFLATE text/html text/css application/javascript image/svg+xml
</IfModule>

# 2. Cache de Navegador (Evita recarregar imagens e CSS a cada clique)
<IfModule mod_expires.c>
    ExpiresActive On
    ExpiresDefault "access plus 1 month"
    ExpiresByType image/webp "access plus 1 year"
    ExpiresByType image/png "access plus 1 year"
    ExpiresByType image/jpeg "access plus 1 year"
    ExpiresByType text/css "access plus 1 month"
</IfModule>

# --- Regras de Roteamento Limpas ---

# Páginas institucionais
RewriteRule ^sobre/?$ sobre.php [L]
RewriteRule ^servicos/?$ servicos.php [L]
RewriteRule ^transparencia/?$ transparencia.php [L]
RewriteRule ^contato/?$ contato.php [L]

# Se for um arquivo ou pasta real, não aplica reescrita
RewriteCond %{REQUEST_FILENAME} -f [OR]
RewriteCond %{REQUEST_FILENAME} -d
RewriteRule ^ - [L]